    public function test_update_menu_item_success(): void
    {
        $menu_id = 42;
        $item_id = 101;
        Functions\when('wp_update_nav_menu_item')->justReturn($item_id);
        $item = (object) [
            'ID' => $item_id,
            'title' => 'Updated Home',
            'url' => '/home',
            'menu_item_parent' => 0,
            'menu_order' => 2,
            'type' => 'custom',
            'target' => '',
            'classes' => [],
            'xfn' => '',
        ];
        Functions\when('get_post')->justReturn((object) ['ID' => $item_id]);
        Functions\when('wp_setup_nav_menu_item')->justReturn($item);

        $controller = $this->make_controller();
        $request = new WP_REST_Request('PUT', [
            'id' => $item_id,
            'menu_id' => $menu_id,
            'label' => 'Updated Home',
            'url' => '/home',
            'parent' => 0,
            'position' => 2,
        ]);
        $response = $controller->update_menu_item($request);

        $this->assertInstanceOf(WP_REST_Response::class, $response);
        $data = $response->get_data();
        $this->assertArrayHasKey('item', $data);
        $this->assertSame($item_id, $data['item']['id']);
        $this->assertSame('Updated Home', $data['item']['label']);
        $this->assertSame('/home', $data['item']['url']);
    }

    public function test_update_menu_item_partial_updates(): void
    {
        $menu_id = 42;
        $item_id = 101;
        Functions\when('wp_update_nav_menu_item')->justReturn($item_id);
        $item = (object) [
            'ID' => $item_id,
            'title' => 'Original',
            'url' => '/',
            'menu_item_parent' => 0,
            'menu_order' => 1,
            'type' => 'custom',
            'target' => '',
            'classes' => [],
            'xfn' => '',
        ];
        Functions\when('get_post')->justReturn((object) ['ID' => $item_id]);
        Functions\when('wp_setup_nav_menu_item')->justReturn($item);

        $controller = $this->make_controller();
        $request = new WP_REST_Request('PUT', [
            'id' => $item_id,
            'menu_id' => $menu_id,
            'label' => 'Updated Label',
        ]);
        $response = $controller->update_menu_item($request);

        $this->assertInstanceOf(WP_REST_Response::class, $response);
        $data = $response->get_data();
        $this->assertArrayHasKey('item', $data);
        $this->assertSame('Updated Label', $data['item']['label']);
        // url unchanged (not provided)
        $this->assertSame('/', $data['item']['url']);
    }

