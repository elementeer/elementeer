    // ------------------------------------------------------------------ //
    // Menu Locations
    // ------------------------------------------------------------------ //

    public function test_list_menu_locations_success(): void
    {
        $locations = [
            'primary' => 'Primary Menu',
            'footer' => 'Footer Menu',
        ];
        $assigned = ['primary' => 42];
        Functions\when('get_registered_nav_menus')->justReturn($locations);
        Functions\when('get_theme_mod')->justReturn($assigned);

        $controller = $this->make_controller();
        $request = new WP_REST_Request('GET');
        $response = $controller->list_menu_locations($request);

        $this->assertInstanceOf(WP_REST_Response::class, $response);
        $data = $response->get_data();
        $this->assertArrayHasKey('locations', $data);
        $this->assertCount(2, $data['locations']);
        $this->assertSame(2, $data['total']);
        $primary = $data['locations'][0];
        $this->assertSame('primary', $primary['location']);
        $this->assertSame('Primary Menu', $primary['description']);
        $this->assertSame(42, $primary['menu_id']);
        $footer = $data['locations'][1];
        $this->assertSame('footer', $footer['location']);
        $this->assertSame('Footer Menu', $footer['description']);
        $this->assertNull($footer['menu_id']);
    }

    public function test_list_menu_locations_empty(): void
    {
        Functions\when('get_registered_nav_menus')->justReturn([]);
        Functions\when('get_theme_mod')->justReturn([]);

        $controller = $this->make_controller();
        $request = new WP_REST_Request('GET');
        $response = $controller->list_menu_locations($request);

        $this->assertInstanceOf(WP_REST_Response::class, $response);
        $data = $response->get_data();
        $this->assertArrayHasKey('locations', $data);
        $this->assertSame([], $data['locations']);
    }

    public function test_list_menu_locations_unauthorized(): void
    {
        $controller = new Menus();
        $auth = Mockery::mock(Manager::class);
        $auth->shouldReceive('authorize')->andReturn(
            new WP_Error(
                'unauthorized',
                'Missing capability theme-structure:read',
                ['status' => 403]
            )
        );
        $ref = new \ReflectionProperty(Menus::class, 'auth');
        $ref->setValue($controller, $auth);

        $request = new WP_REST_Request('GET');
        $response = $controller->list_menu_locations($request);

        $this->assertInstanceOf(WP_Error::class, $response);
        $this->assertSame('unauthorized', $response->get_error_code());
    }

    public function test_assign_menu_location_success(): void
    {
        $locations = [];
        Functions\when('get_theme_mod')->justReturn($locations);
        Functions\when('set_theme_mod')->alias(
            static function ($key, $value) use (&$locations) {
                $locations = $value;
                return true;
            }
        );

        $controller = $this->make_controller();
        $request = new WP_REST_Request('POST', [
            'menu_id' => 42,
            'location' => 'primary',
        ]);
        $response = $controller->assign_menu_location($request);

        $this->assertInstanceOf(WP_REST_Response::class, $response);
        $data = $response->get_data();
        $this->assertArrayHasKey('message', $data);
        $this->assertArrayHasKey('location', $data);
        $this->assertArrayHasKey('menu_id', $data);
        $this->assertSame('primary', $data['location']);
        $this->assertSame(42, $data['menu_id']);
    }

    public function test_assign_menu_location_invalid_params(): void
    {
        $controller = $this->make_controller();
        $request = new WP_REST_Request('POST', [
            'menu_id' => 0,
            'location' => '',
        ]);
        $response = $controller->assign_menu_location($request);

        $this->assertInstanceOf(WP_Error::class, $response);
        $this->assertSame('invalid_param', $response->get_error_code());
    }

    public function test_assign_menu_location_unauthorized(): void
    {
        $controller = new Menus();
        $auth = Mockery::mock(Manager::class);
        $auth->shouldReceive('authorize')->andReturn(
            new WP_Error(
                'unauthorized',
                'Missing capability theme-structure:write',
                ['status' => 403]
            )
        );
        $ref = new \ReflectionProperty(Menus::class, 'auth');
        $ref->setValue($controller, $auth);

        $request = new WP_REST_Request('POST', [
            'menu_id' => 42,
            'location' => 'primary',
        ]);
        $response = $controller->assign_menu_location($request);

        $this->assertInstanceOf(WP_Error::class, $response);
        $this->assertSame('unauthorized', $response->get_error_code());
    }

    private function make_controller(): Menus
    {
        $controller = new Menus();
        $auth = Mockery::mock(Manager::class);
        $auth->shouldReceive('authorize')->andReturn(
            [
                'key' => 'ek_test',
                'label' => 'Test Key',
                'capabilities' => ['theme-structure:read', 'theme-structure:write'],
                'is_active' => true,
            ]
        );

        $ref = new \ReflectionProperty(Menus::class, 'auth');
        $ref->setValue($controller, $auth);

        return $controller;
    }
}
