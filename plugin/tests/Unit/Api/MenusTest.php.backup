    public function test_list_menu_items_success(): void
    {
        $items = [
            (object) [
                'ID' => 101,
                'title' => 'Home',
                'url' => '/',
                'menu_item_parent' => 0,
                'menu_order' => 1,
                'type' => 'custom',
                'target' => '',
                'classes' => [],
                'xfn' => '',
            ],
            (object) [
                'ID' => 102,
                'title' => 'About',
                'url' => '/about',
                'menu_item_parent' => 0,
                'menu_order' => 2,
                'type' => 'post_type',
                'target' => '_blank',
                'classes' => ['menu-item'],
                'xfn' => 'nofollow',
            ],
        ];
        Functions\when('wp_get_nav_menu_items')->justReturn($items);

        $controller = $this->make_controller();
        $request = new WP_REST_Request('GET', ['menu_id' => 42]);
        $response = $controller->list_menu_items($request);

        $this->assertInstanceOf(WP_REST_Response::class, $response);
        $data = $response->get_data();
        $this->assertArrayHasKey('items', $data);
        $this->assertCount(2, $data['items']);
        $this->assertSame(2, $data['total']);
        $this->assertSame(101, $data['items'][0]['id']);
        $this->assertSame('Home', $data['items'][0]['label']);
        $this->assertSame('/', $data['items'][0]['url']);
    }

