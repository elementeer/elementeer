<?php

declare(strict_types=1);

namespace Elementify\Tests\Unit\Api;

use Brain\Monkey;
use Brain\Monkey\Functions;
use Elementify\MCP\Api\Menus;
use Elementify\MCP\Auth\Manager;
use Mockery;
use PHPUnit\Framework\TestCase;
use WP_Error;
use WP_REST_Request;
use WP_REST_Response;

class MenusTest extends TestCase
{
    protected function setUp(): void
    {
        parent::setUp();
        Monkey\setUp();

        Functions\when('is_wp_error')->alias(
            static function($value): bool {
                return $value instanceof WP_Error;
            }
        );
        Functions\when('sanitize_text_field')->returnArg();
        Functions\when('sanitize_textarea_field')->returnArg();
        Functions\when('esc_url_raw')->returnArg();
        Functions\when('absint')->alias(
            static function($value): int {
                return (int) $value;
            }
        );
    }

    protected function tearDown(): void
    {
        Monkey\tearDown();
        Mockery::close();
        parent::tearDown();
    }

    // ------------------------------------------------------------------ //
    // Menus
    // ------------------------------------------------------------------ //

    public function test_list_menus_returns_all_navigation_menus(): void
    {
        $menus = [
            (object) [
                'term_id' => 1,
                'name' => 'Main Menu',
                'slug' => 'main-menu',
                'count' => 5,
                'description' => 'Primary navigation',
            ],
            (object) [
                'term_id' => 2,
                'name' => 'Footer Menu',
                'slug' => 'footer-menu',
                'count' => 3,
                'description' => 'Footer links',
            ],
        ];
        Functions\when('wp_get_nav_menus')->justReturn($menus);

        $controller = $this->make_controller();
        $request = new WP_REST_Request('GET');
        $response = $controller->list_menus($request);

        $this->assertInstanceOf(WP_REST_Response::class, $response);
        $data = $response->get_data();
        $this->assertArrayHasKey('menus', $data);
        $this->assertCount(2, $data['menus']);
        $this->assertSame(2, $data['total']);
        $this->assertSame(1, $data['menus'][0]['id']);
        $this->assertSame('Main Menu', $data['menus'][0]['name']);
        $this->assertSame('main-menu', $data['menus'][0]['slug']);
        $this->assertSame(5, $data['menus'][0]['count']);
        $this->assertSame('Primary navigation', $data['menus'][0]['description']);
    }

    public function test_list_menus_returns_empty_array_on_failure(): void
    {
        Functions\when('wp_get_nav_menus')->justReturn(false);

        $controller = $this->make_controller();
        $request = new WP_REST_Request('GET');
        $response = $controller->list_menus($request);

        $this->assertInstanceOf(WP_REST_Response::class, $response);
        $data = $response->get_data();
        $this->assertArrayHasKey('menus', $data);
        $this->assertSame([], $data['menus']);
    }

    public function test_list_menus_unauthorized(): void
    {
        $controller = new Menus();
        $auth = Mockery::mock(Manager::class);
        $auth->shouldReceive('authorize')->andReturn(
            new WP_Error(
                'unauthorized',
                'Missing capability theme-structure:read',
                ['status' => 403]
            )
        );
        $ref = new \ReflectionProperty(Menus::class, 'auth');
        $ref->setValue($controller, $auth);

        $request = new WP_REST_Request('GET');
        $response = $controller->list_menus($request);

        $this->assertInstanceOf(WP_Error::class, $response);
        $this->assertSame('unauthorized', $response->get_error_code());
    }

    public function test_create_menu_success(): void
    {
        $menu_id = 42;
        Functions\when('wp_create_nav_menu')->justReturn($menu_id);
        $menu_object = (object) [
            'term_id' => $menu_id,
            'name' => 'New Menu',
            'slug' => 'new-menu',
            'count' => 0,
            'description' => '',
        ];
        Functions\when('wp_get_nav_menu_object')->justReturn($menu_object);

        $controller = $this->make_controller();
        $request = new WP_REST_Request('POST', ['name' => 'New Menu']);
        $response = $controller->create_menu($request);

        $this->assertInstanceOf(WP_REST_Response::class, $response);
        $this->assertSame(201, $response->get_status());
        $data = $response->get_data();
        $this->assertArrayHasKey('menu', $data);
        $this->assertSame($menu_id, $data['menu']['id']);
        $this->assertSame('New Menu', $data['menu']['name']);
        $this->assertArrayHasKey('message', $data);
    }

